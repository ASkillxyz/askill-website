# ─── Supabase ─────────────────────────────────────────────────────────────────
# 在 Supabase Dashboard → Settings → API 中获取
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ─── NextAuth ─────────────────────────────────────────────────────────────────
# 随机生成：openssl rand -base64 32
NEXTAUTH_SECRET=your-random-secret-here
NEXTAUTH_URL=http://localhost:3000

# ─── GitHub OAuth（登录用）────────────────────────────────────────────────────
# https://github.com/settings/developers → New OAuth App
# Authorization callback URL: http://localhost:3000/api/auth/callback/github
GITHUB_CLIENT_ID=your-github-oauth-client-id
GITHUB_CLIENT_SECRET=your-github-oauth-client-secret

# ─── Google OAuth（登录用）────────────────────────────────────────────────────
# https://console.cloud.google.com/ → APIs & Services → Credentials
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ─── GitHub Token（上传技能创建 PR 用）────────────────────────────────────────
# https://github.com/settings/tokens → Fine-grained token
# 权限：Contents(read&write) + Pull Requests(read&write)
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx

# ─── GitHub Skills Repo（你用来存 SKILL.md 的仓库）──────────────────────────
GITHUB_SKILLS_OWNER=your-github-username
GITHUB_SKILLS_REPO=askill-skills
GITHUB_BASE_BRANCH=main
